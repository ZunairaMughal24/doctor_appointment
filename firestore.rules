rules_version = '2';

// Firestore security rules for the doctor-appointment app.
//
// These are sensible development rules: every collection requires the caller to
// be signed in, notifications are readable only by their recipient, and writes
// are open to any authenticated user (needed because a patient creates a
// notification doc addressed to a doctor when booking, and the app self-heals
// seed doctor docs). Tighten further before a public production launch.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // User profiles + FCM tokens. A user manages their own document.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Doctor profiles: publicly readable (home/list/detail). Any signed-in user
    // may write — covers a doctor editing their own profile / imageUrl /
    // fcmToken, and the app's seed self-heal on first load.
    match /doctors/{docId} {
      allow read: if true;
      allow write: if signedIn();
    }

    // Appointments are read/written by the patient and the doctor involved.
    match /appointments/{id} {
      allow read, write: if signedIn();
    }

    // Slot locks that prevent double-booking.
    match /booked_slots/{id} {
      allow read, write: if signedIn();
    }

    // In-app notifications. Readable only by the recipient; any signed-in user
    // may create one (e.g. a patient notifying a doctor) or mark it read. The
    // recipient may delete their own (used by account deletion).
    match /notifications/{id} {
      allow read: if signedIn() && resource.data.user_id == request.auth.uid;
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }
  }
}
